generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Game {
  game_id     String        @id @default(uuid()) @db.VarChar(36)
  game_name   String        @db.VarChar(255)
  description String        @db.VarChar(255)
  categories  RunCategory[]

  @@map("games")
}

model RunCategory {
  run_category_id   String @id @default(uuid()) @db.VarChar(36)
  game_id           String @db.VarChar(36)
  run_category_name String @db.VarChar(255)
  game              Game   @relation(fields: [game_id], references: [game_id], onDelete: Cascade, map: "fk_run_categories_game")

  @@index([game_id], map: "fk_run_categories_game")
  @@map("run_categories")
}
